# Токен Telegram-бота от @BotFather
BOT_TOKEN=your-telegram-bot-token-here

# Язык бота (en, ru). По умолчанию: ru
# Доступные языки: configs/i18n/
BOT_LANG=ru

# Порт веб-интерфейса (по умолчанию: 3000)
PORT=3000

# Анти-флуд для веб /generate
# Окно лимита в миллисекундах и максимум запросов за окно
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERATE_MAX=15
# Установите 1, если используете reverse proxy (nginx/cloudflare) для корректного IP
TRUST_PROXY=0

# Анти-флуд для Telegram-бота
# Максимум действий за окно и кулдаун между генерациями
BOT_FLOOD_WINDOW_SEC=10
BOT_FLOOD_MAX_EVENTS=8
BOT_GENERATE_COOLDOWN_SEC=20
