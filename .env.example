# Токен Telegram-бота от @BotFather
BOT_TOKEN=your-telegram-bot-token-here

# Язык бота (en, ru). По умолчанию: ru
# Доступные языки: configs/i18n/
BOT_LANG=ru

# Порт веб-интерфейса (по умолчанию: 3000)
PORT=3000

# Ограничение запросов к генерации в вебе (anti-flood)
# Окно лимита в миллисекундах (по умолчанию: 60000)
WEB_RATE_LIMIT_WINDOW_MS=60000
# Максимум запросов /generate за окно с одного IP (по умолчанию: 10)
WEB_RATE_LIMIT_MAX_REQUESTS=10

# Минимальная пауза между генерациями в боте для одного пользователя, сек (по умолчанию: 30)
BOT_GENERATION_COOLDOWN_SECONDS=30
